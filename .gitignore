# Local Claude Code config (personal, not shared)
.claude/

# Flutter/Dart build artifacts (each app also has its own .gitignore;
# these are repo-root safety nets so the multi-GB build dirs never get staged)
**/build/
**/.dart_tool/
**/.flutter-plugins-dependencies
**/.testlib/

# Release signing — NEVER commit keystores or passwords
**/key.properties
**/*.jks
**/*.keystore
**/upload-keystore.jks
# Base64-encoded keystores are the signing secret in another form
**/*.b64
**/keystore.b64

# IDE / OS
*.iml
.idea/
.DS_Store
